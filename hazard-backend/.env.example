# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/hazard_db"

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_to_a_long_random_string_at_least_64_chars"
JWT_EXPIRES_IN="7d"

# ─── S3 / Object Storage ──────────────────────────────────────────────────────
# Works with AWS S3, Cloudflare R2, or MinIO
S3_ENDPOINT="https://s3.amazonaws.com"          # Omit for AWS; set for R2/MinIO
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your_access_key_id"
S3_SECRET_ACCESS_KEY="your_secret_access_key"
S3_BUCKET_NAME="hazard-reports"
S3_PUBLIC_URL="https://your-bucket.s3.amazonaws.com" # Public base URL for photos

# ─── Routing ──────────────────────────────────────────────────────────────────
# Use the public OSRM demo server for development; self-host for production.
OSRM_BASE_URL="https://router.project-osrm.org"
# Optional: Mapbox token (if you prefer Mapbox Directions API)
MAPBOX_TOKEN=""

# ─── Hazard Report Settings ───────────────────────────────────────────────────
REPORT_TTL_HOURS=6                    # Reports expire after this many hours
HAZARD_AVOIDANCE_RADIUS_METERS=150   # Buffer radius around each hazard for routing
TRUSTED_REPORTER_THRESHOLD=10        # reportsCount needed to become "Trusted Reporter"
DEV_BYPASS_AUTH=true